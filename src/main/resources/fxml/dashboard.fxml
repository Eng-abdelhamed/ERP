<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.DashboardController"
            prefWidth="1100" prefHeight="700"
            styleClass="root-pane">

    <!-- TOP BAR -->
    <top>
        <HBox styleClass="topbar" spacing="12" alignment="CENTER_LEFT" prefHeight="60">
            <padding>
                <Insets right="24" left="24"/>
            </padding>

            <!-- Brand -->
            <Label text="" styleClass="logo"/>
            <Label text="ERP SYSTEM" styleClass="title"/>
            
            <!-- Spacer -->
            <Region HBox.hgrow="ALWAYS"/>
            
            <!-- Profile Placeholder -->
            <HBox alignment="CENTER" style="-fx-padding: 0 8 0 0;">
                <Label text="Admin User" styleClass="form-label"/>
            </HBox>

            <!-- Theme Toggle -->
            <Button text="🌓"
                    onAction="#toggleTheme"
                    styleClass="btn-ghost"
                    style="-fx-font-size: 18px; -fx-padding: 6 10;"/>
        </HBox>
    </top>

    <!-- LEFT SIDEBAR -->
    <left>
        <VBox styleClass="sidebar" spacing="6" prefWidth="240">
            <padding>
                <Insets top="24" right="16" bottom="24" left="16"/>
            </padding>

            <Label text="OVERVIEW" styleClass="menu-title"/>

            <Button text="   Dashboard"
                    fx:id="btnDashboard"
                    onAction="#handleShowDashboard"
                    maxWidth="Infinity"
                    styleClass="side-btn, active"/>

            <Region prefHeight="16"/>
            <Label text="MANAGEMENT" styleClass="menu-title"/>

            <Button text="  👥 Employees"
                    fx:id="btnEmployees"
                    onAction="#handleShowEmployees"
                    maxWidth="Infinity"
                    styleClass="side-btn"/>

            <Button fx:id="btnPayroll" text="  💰 Payroll"
                    onAction="#handleShowPayroll"
                    maxWidth="Infinity"
                    styleClass="side-btn"/>

            <Button fx:id="btnAttendance" text="  📅 Attendance"
                    onAction="#handleShowAttendance"
                    maxWidth="Infinity"
                    styleClass="side-btn"/>

            <Button fx:id="btnReports" text="  📈 Reports"
                    onAction="#handleShowReports"
                    maxWidth="Infinity"
                    styleClass="side-btn"/>
        </VBox>
    </left>

    <!-- CENTER CONTENT -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-padding: 0; -fx-border-width: 0;">
            <VBox fx:id="contentArea"
                  spacing="24"
                  styleClass="content">
    
                <padding>
                    <Insets top="32" right="40" bottom="32" left="40"/>
                </padding>
    
                <!-- Header -->
                <VBox spacing="4">
                    <Label text="Overview"
                           styleClass="page-title"
                           fx:id="welcomeLabel"/>
                    <Label text="Here's what's happening with your company today."
                           styleClass="page-subtitle"/>
                </VBox>
                
                <!-- KPI Grid -->
                <GridPane hgap="24" vgap="24">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="33.33"/>
                        <ColumnConstraints percentWidth="33.33"/>
                        <ColumnConstraints percentWidth="33.33"/>
                    </columnConstraints>
                    
                    <!-- KPI 1 -->
                    <VBox styleClass="stat-card" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <Label text="Total Employees" styleClass="stat-title"/>
                        <Region prefHeight="12"/>
                        <Label fx:id="lblTotalEmployees" text="0" styleClass="stat-value"/>
                        <Region prefHeight="4"/>
                        <Label fx:id="lblEmployeesSub" text="registered in system" style="-fx-text-fill: -color-text-muted; -fx-font-size: 12px;"/>
                    </VBox>
                    
                    <!-- KPI 2 -->
                    <VBox styleClass="stat-card" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <Label text="Attendance Records" styleClass="stat-title"/>
                        <Region prefHeight="12"/>
                        <Label fx:id="lblTotalAttendance" text="0" styleClass="stat-value"/>
                        <Region prefHeight="4"/>
                        <Label fx:id="lblAttendanceSub" text="logs recorded" style="-fx-text-fill: -color-text-muted; -fx-font-size: 12px;"/>
                    </VBox>
                    
                    <!-- KPI 3 -->
                    <VBox styleClass="stat-card" GridPane.columnIndex="2" GridPane.rowIndex="0">
                        <Label text="Payroll Records" styleClass="stat-title"/>
                        <Region prefHeight="12"/>
                        <Label fx:id="lblTotalPayroll" text="0" styleClass="stat-value"/>
                        <Region prefHeight="4"/>
                        <Label fx:id="lblPayrollSub" text="processed entries" style="-fx-text-fill: -color-text-muted; -fx-font-size: 12px;"/>
                    </VBox>
                </GridPane>
                
                <!-- Chart Placeholders -->
                <GridPane hgap="24" vgap="24" VBox.vgrow="ALWAYS">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="66.66"/>
                        <ColumnConstraints percentWidth="33.33"/>
                    </columnConstraints>
                    
                    <VBox styleClass="card" GridPane.columnIndex="0" GridPane.rowIndex="0" minHeight="260">
                        <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>
                        <Label text="Activity Overview" styleClass="card-title"/>
                        <VBox spacing="14">
                            <Label fx:id="lblActivityLine1" text="Loading..." style="-fx-text-fill: -color-text-muted; -fx-font-size: 13px;"/>
                            <Label fx:id="lblActivityLine2" text="" style="-fx-text-fill: -color-text-main; -fx-font-size: 14px; -fx-font-weight: 600;"/>
                            <Label fx:id="lblActivityLine3" text="" style="-fx-text-fill: -color-success; -fx-font-size: 14px; -fx-font-weight: 600;"/>
                            <Label fx:id="lblActivityLine4" text="" style="-fx-text-fill: -color-danger; -fx-font-size: 14px; -fx-font-weight: 600;"/>
                            <Label fx:id="lblActivityLine5" text="" style="-fx-text-fill: -color-primary; -fx-font-size: 14px; -fx-font-weight: 700;"/>
                        </VBox>
                    </VBox>
                    
                    <VBox styleClass="card" GridPane.columnIndex="1" GridPane.rowIndex="0" minHeight="260">
                        <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>
                        <Label text="Recent Events" styleClass="card-title"/>
                        <VBox spacing="16">
                            <!-- Event 1 -->
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Region style="-fx-background-color: -color-primary; -fx-min-width: 8; -fx-min-height: 8; -fx-background-radius: 50%;"/>
                                <VBox>
                                    <Label fx:id="lblEvent1Title" text="—" style="-fx-font-weight: 600; -fx-text-fill: -color-text-main; -fx-font-size: 12px;"/>
                                    <Label fx:id="lblEvent1Time"  text="—" style="-fx-font-size: 11px; -fx-text-fill: -color-text-muted;"/>
                                </VBox>
                            </HBox>
                            <!-- Event 2 -->
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Region style="-fx-background-color: -color-success; -fx-min-width: 8; -fx-min-height: 8; -fx-background-radius: 50%;"/>
                                <VBox>
                                    <Label fx:id="lblEvent2Title" text="—" style="-fx-font-weight: 600; -fx-text-fill: -color-text-main; -fx-font-size: 12px;"/>
                                    <Label fx:id="lblEvent2Time"  text="—" style="-fx-font-size: 11px; -fx-text-fill: -color-text-muted;"/>
                                </VBox>
                            </HBox>
                            <!-- Event 3 -->
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Region style="-fx-background-color: -color-text-muted; -fx-min-width: 8; -fx-min-height: 8; -fx-background-radius: 50%;"/>
                                <VBox>
                                    <Label fx:id="lblEvent3Title" text="—" style="-fx-font-weight: 600; -fx-text-fill: -color-text-main; -fx-font-size: 12px;"/>
                                    <Label fx:id="lblEvent3Time"  text="—" style="-fx-font-size: 11px; -fx-text-fill: -color-text-muted;"/>
                                </VBox>
                            </HBox>
                        </VBox>
                    </VBox>
                </GridPane>
    
            </VBox>
        </ScrollPane>
    </center>

</BorderPane>